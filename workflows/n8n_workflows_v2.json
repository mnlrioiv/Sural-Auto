  {
    "name": "Lead Reception & Qualification",
    "nodes": [
      {
        "parameters": {
          "httpMethod": {"__rl": true, "mode": "list", "value": "POST"},
          "path": "lead-calificacion",
          "responseMode": "lastNode",
          "options": {}
        },
        "id": "wh1",
        "name": "Webhook Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "webhookId": "lead-calificacion",
        "position": [250, 300]
      },
      {
        "parameters": {
          "jsCode": "const d = $input.first().json;\nconst body = d.body || d;\nlet score = 0;\nlet tag = \"lead_frio\";\nif (body.email && body.email.includes(\"@\")) score += 20;\nif (body.telefono && body.telefono.length > 7) score += 25;\nif (body.empresa) score += 15;\nif (body.mensaje && body.mensaje.length > 20) score += 20;\nif (body.interes === \"plataforma completa\") { score += 20; tag = \"lead_quente\"; }\nelse if (body.interes === \"automatizacion\") { score += 15; tag = \"lead_morno\"; }\nconst tam = body.empleados || \"\";\nif (tam.includes(\"21\") || tam.includes(\"51\")) { score += 15; tag = \"lead_quente\"; }\nconst result = {...body, lead_score: score, lead_tag: tag, timestamp: new Date().toISOString()};\nreturn [{json: result}, {json: {...result, branch: result.lead_score >= 50 ? \"quente\" : \"frio\"}}];"
        },
        "id": "code1",
        "name": "Procesar Lead",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [550, 300]
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst quente = items.find(i => i.json.branch === \"quente\");\nconst frio = items.find(i => i.json.branch === \"frio\");\nif (quente) return [quente];\nreturn [frio];"
        },
        "id": "code2",
        "name": "Routing quente",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [850, 150]
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst quente = items.find(i => i.json.branch === \"quente\");\nconst frio = items.find(i => i.json.branch === \"frio\");\nif (frio) return [frio];\nreturn [quente];"
        },
        "id": "code3",
        "name": "Routing frio",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [850, 450]
      },
