        "typeVersion": 1,
        "webhookId": "soporte-ticket",
        "position": [250, 300]
      },
      {
        "parameters": {
          "jsCode": "const body = $input.first().json.body || $input.first().json;\nlet priority = \"normal\";\nconst msg = (body.mensaje || \"\").toLowerCase();\nif (msg.includes(\"urgente\") || msg.includes(\"down\")) priority = \"urgente\";\nelse if (msg.includes(\"factura\") || msg.includes(\"pago\")) priority = \"facturacion\";\nconst result = {...body, priority: priority, ticket_id: Date.now().toString()};\nreturn [{json: result}, {json: {...result, branch: priority === \"urgente\" ? \"urgente\" : \"normal\"}}];"
        },
        "id": "code2a",
        "name": "Clasificar",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [550, 300]
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\nreturn items.filter(i => i.json.branch === \"urgente\");"
        },
        "id": "code2b",
        "name": "Split urgente",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [850, 150]
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\nreturn items.filter(i => i.json.branch !== \"urgente\");"
        },
        "id": "code2c",
        "name": "Split normal",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [850, 450]
      },
      {
        "parameters": {
          "to": "={{ $json.email }}",
          "subject": "[URGENTE] Recibimos tu consulta - Sural",
          "text": "=Hola {{ $json.nombre }},\\n\\nRecibimos tu mensaje urgente. Te respondemos en menos de 1 hora.\\n\\nEquipo Sural",
          "options": {}
        },
        "id": "em2a",
        "name": "Email urgente",
        "type": "n8n-nodes-base.emailSend",
        "typeVersion": 1,
        "position": [1150, 150]
      },
      {
        "parameters": {
          "to": "={{ $json.email }}",
          "subject": "Recibimos tu consulta - Sural",
          "text": "=Hola {{ $json.nombre }},\\n\\nGracias por contactingarnos. Te responderemos en 24 horas.\\n\\nEquipo Sural",
          "options": {}
        },
        "id": "em2b",
