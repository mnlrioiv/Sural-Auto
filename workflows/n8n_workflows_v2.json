      "Clasificar": {"main": [[{"node": "Split urgente", "type": "main", "index": 0}], [{"node": "Split normal", "type": "main", "index": 0}]]},
      "Split urgente": {"main": [[{"node": "Email urgente", "type": "main", "index": 0}]]},
